      "params": {
        "cutoff": 5200,
        "resonance": 1.1,
        "osc2Type": "sawtooth",
        "osc2Level": 0.45,
        "osc2Detune": 14,
        "unisonVoices": 3,
        "unisonWidth": 0.5,
        "filterEnvAmount": 0.3,
        "filterEnvDecay": 0.2,
        "sendDelay": 0.4,
        "sendReverb": 0.25,
        "eqHigh": 1.5
