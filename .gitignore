node_modules/
dist/
.DS_Store
*.log
dist-headless/
.freesound-tokens.json

# Tauri desktop shell (D1) — Rust build artifacts, never committed. (Cargo.lock IS committed,
# per Rust convention for applications — reproducible builds.)
target/

# beatlab is cloned as a scratch checkout outside the repo for desktop dev/testing — if anyone
# ever clones it *inside* the worktree by mistake, don't let it land in git history.
/beatlab/

# Reference material for research (e.g. Ableton's own manual) — large binaries, never committed.
/prior_art/

# Owner-side Python venv for the ML sidecars (python/README.md) — machine-local, never committed.
python/.venv/

# CLI render outputs inside example projects — regenerable from the .beat + media.
examples/*/render-*.wav
examples/media/*.sf2
