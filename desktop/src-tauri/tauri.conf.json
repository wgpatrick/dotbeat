{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dotbeat",
  "version": "0.1.0",
  "identifier": "com.dotbeat.desktop",
  "build": {
    "devUrl": "http://localhost:5300",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../../ui"
    },
    "frontendDist": "../../ui/dist",
    "beforeBuildCommand": {
      "script": "node ../desktop/sidecar/build.mjs && npm run build",
      "cwd": "../../ui"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "dotbeat",
        "width": 1280,
        "height": 860
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/dotbeat-daemon"]
  }
}
